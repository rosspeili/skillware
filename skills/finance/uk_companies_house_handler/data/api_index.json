{
  "base_url": "https://api.company-information.service.gov.uk",
  "auth": {
    "method": "http_basic",
    "username": "api_key",
    "password": "empty",
    "docs": "https://developer.company-information.service.gov.uk/"
  },
  "rate_limit": {
    "requests_per_five_minutes": 600,
    "note": "Rate limits apply per API key. 429 responses indicate throttling."
  },
  "endpoints": {
    "search_companies": {
      "method": "GET",
      "path": "/search/companies",
      "description": "Search for companies by name or number.",
      "params": {
        "q": {
          "type": "string",
          "required": true,
          "description": "Company name or number search query"
        },
        "items_per_page": {
          "type": "integer",
          "required": false,
          "default": 20,
          "max": 100,
          "description": "Number of results per page"
        },
        "start_index": {
          "type": "integer",
          "required": false,
          "default": 0,
          "description": "Offset for pagination"
        }
      },
      "response_key": "items"
    },
    "get_company_profile": {
      "method": "GET",
      "path": "/company/{company_number}",
      "description": "Get the full profile for a specific company.",
      "params": {},
      "response_key": null
    },
    "get_officers": {
      "method": "GET",
      "path": "/company/{company_number}/officers",
      "description": "List officers (directors, secretaries) for a company.",
      "params": {
        "items_per_page": {
          "type": "integer",
          "required": false,
          "description": "Number of results per page"
        },
        "start_index": {
          "type": "integer",
          "required": false,
          "description": "Offset for pagination"
        },
        "order_by": {
          "type": "string",
          "required": false,
          "enum": ["appointed_on", "resigned_on", "surname"],
          "description": "Sort order for results"
        }
      },
      "response_key": "items"
    },
    "get_pscs": {
      "method": "GET",
      "path": "/company/{company_number}/persons-with-significant-control",
      "description": "List persons with significant control (beneficial owners).",
      "params": {
        "items_per_page": {
          "type": "integer",
          "required": false,
          "description": "Number of results per page"
        },
        "start_index": {
          "type": "integer",
          "required": false,
          "description": "Offset for pagination"
        },
        "register_view": {
          "type": "boolean",
          "required": false,
          "description": "Show only active PSCs when true"
        }
      },
      "response_key": "items"
    },
    "get_filing_history": {
      "method": "GET",
      "path": "/company/{company_number}/filing-history",
      "description": "List filing history for a company.",
      "params": {
        "category": {
          "type": "string",
          "required": false,
          "description": "Filter by filing category (e.g. accounts, confirmation-statement)"
        },
        "items_per_page": {
          "type": "integer",
          "required": false,
          "description": "Number of results per page"
        },
        "start_index": {
          "type": "integer",
          "required": false,
          "description": "Offset for pagination"
        }
      },
      "response_key": "items"
    }
  },
  "v2_planned": [
    "charges",
    "registers",
    "insolvency",
    "document_metadata",
    "document_fetch",
    "search_officers",
    "search_disqualified_officers"
  ]
}
